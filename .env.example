# WooCommerce – set these in Render dashboard as Environment Variables
WC_URL=https://your-store-url.com
WC_CONSUMER_KEY=your_consumer_key_here
WC_CONSUMER_SECRET=your_consumer_secret_here

# OpenRouter AI – get a free key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_openrouter_key_here
AI_MODEL=nvidia/nemotron-3-nano-30b-a3b:free
